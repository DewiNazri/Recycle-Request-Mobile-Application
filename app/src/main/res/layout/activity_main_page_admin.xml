<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:id="@+id/main_page_admin"
    android:background="@drawable/admin">

    <!-- Logout Button at Top Right -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:onClick="logoutClicked"
        android:backgroundTint="#FF6B6B"
        android:textColor="#FFFFFF"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="16dp" />

    <!-- Centered Content -->
    <LinearLayout
        android:id="@+id/centerContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnLogout"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Page"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#5c0909"
            android:layout_marginTop="16dp" />

        <!-- View Request Button -->
        <Button
            android:id="@+id/viewRequestButton"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="Customer's Request"
            android:onClick="viewAllRequestClicked"
            android:backgroundTint="#6BCB77"
            android:layout_marginTop="100dp" />

        <!-- List Item Button -->
        <Button
            android:id="@+id/listItemButton"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="List Item"
            android:onClick="listItemClicked"
            android:backgroundTint="#6BCB77"
            android:layout_marginTop="20dp" />

        <!-- Add Item Button -->
        <Button
            android:id="@+id/addItemButton"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="Add Item"
            android:onClick="addItemClicked"
            android:backgroundTint="#6BCB77"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/addAnnouncementButton"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="Add Announcement"
            android:onClick="addAnnouncementClicked"
            android:backgroundTint="#6BCB77"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <!-- Summary Cards BELOW the center content -->
    <LinearLayout
        android:id="@+id/summaryLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/centerContent"
        android:layout_marginTop="96dp"
        android:orientation="vertical">

        <!-- Row 1: Total Requests + Revenue -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:gravity="center">

            <!-- Total Requests -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FF7043"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/totalRequest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Requests"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Revenue -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="#42A5F5"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/totalRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RM0.00"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Revenue"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Pending + Completed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2"
            android:gravity="center">

            <!-- Pending -->

            <!-- Completed -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="#FFD54F"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/pendingRequest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#81C784"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/completedRequest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>

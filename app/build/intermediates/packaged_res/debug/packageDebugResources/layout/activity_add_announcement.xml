<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/admin">

    <!-- Top bar with Logout aligned right -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:onClick="logoutClicked"
            android:backgroundTint="#FF6B6B"
            android:textColor="#FFFFFF"
            android:layout_gravity="end"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="16dp"/>
    </FrameLayout>

    <!-- Title input -->

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="Announcement"
        android:textColor="#5c0909"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- Message input -->
    <EditText
        android:id="@+id/announcementTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/edit_text"
        android:hint="Announcement Title"
        android:padding="12dp" />

    <EditText
        android:id="@+id/announcementMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Announcement Message"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:minLines="4"
        android:gravity="top"
        android:layout_marginBottom="32dp"/>

    <!-- Buttons in a horizontal row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            app:cornerRadius="50dp"/>

        <!-- Space between buttons -->
        <View
            android:layout_width="16dp"
            android:layout_height="0dp"/>

        <!-- Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/submitAnnouncementButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Submit"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            app:cornerRadius="50dp"/>
    </LinearLayout>

    <!-- Latest announcement card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLatestAnnouncement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnLogout"
        android:layout_marginTop="24dp"
        android:elevation="4dp"
        app:cardCornerRadius="12dp"
        android:backgroundTint="#FFFFE0"
        android:layout_margin="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvAnnouncementTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tvAnnouncementMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Message here"
                android:textSize="16sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Instruction -->
    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💡 Long press the card to view/hide older announcements"
        android:textColor="#5c0909"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_below="@id/cardLatestAnnouncement"
        android:layout_centerHorizontal="true"/>

    <!-- RecyclerView for older announcements -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOlderAnnouncements"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvInstruction"
        android:layout_marginTop="12dp"
        android:visibility="gone"/>

</LinearLayout>
